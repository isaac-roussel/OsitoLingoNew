      "difficulty": 2,
      "sort_order": 6
    },
    {
      "exercise_type": "translate_en_to_es",
      "prompt": "Where is baggage claim?",
      "answer": "¿Dónde está la recogida de equipaje?",
      "answer_alt": "¿Dónde está equipaje?|¿Dónde está la zona de equipaje?",
      "explanation": "Also heard: 'reclamo de equipaje' in some regions.",
      "difficulty": 2,
      "sort_order": 7
    },
    {
      "exercise_type": "translate_en_to_es",
      "prompt": "I lost my luggage.",
      "answer": "Perdí mi equipaje.",
