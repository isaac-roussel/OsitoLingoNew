  "exercises": [
    {
      "exercise_type": "translate_en_to_es",
      "prompt": "Where is the boarding gate?",
      "answer": "¿Dónde está la puerta de embarque?",
      "answer_alt": "¿En dónde está la puerta de embarque?|¿Dónde queda la puerta de embarque?",
      "explanation": "'Puerta de embarque' = boarding gate.",
      "difficulty": 1,
      "sort_order": 1
    },
    {
      "exercise_type": "translate_en_to_es",
      "prompt": "I need my passport.",
      "answer": "Necesito mi pasaporte.",
      "answer_alt": "Necesito el pasaporte.",
      "explanation": "'Necesito' = I need.",
      "difficulty": 1,
      "sort_order": 2
    },
    {
      "exercise_type": "translate_en_to_es",
      "prompt": "Where is security?",
      "answer": "¿Dónde está seguridad?",
