      "explanation": "Also: 'el control de seguridad' = security checkpoint.",
      "difficulty": 1,
      "sort_order": 3
    },
    {
      "exercise_type": "translate_en_to_es",
      "prompt": "My flight is delayed.",
      "answer": "Mi vuelo está retrasado.",
      "answer_alt": "Mi vuelo se retrasó.",
      "explanation": "'retrasado' = delayed.",
      "difficulty": 2,
      "sort_order": 4
    },
    {
      "exercise_type": "translate_en_to_es",
      "prompt": "What time does the flight depart?",
      "answer": "¿A qué hora sale el vuelo?",
